generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// GHOSTSTUDIO AI — CANONICAL CONTENT SCHEMA
// V2: Full-stack AI media platform
// ============================================================

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  name              String?
  avatar            String?
  password          String?
  role              String          @default("operator") // operator, admin, viewer
  automationMode    String          @default("semi_auto") // manual, semi_auto, full_auto
  plan              String          @default("free") // free, creator, pro, agency
  stripeCustomerId  String?         @unique
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  workspaces        Workspace[]
  apiCredentials    ApiCredential[]
  subscriptions     Subscription[]
  videoProjects     VideoProject[]
  workspaceMembers  WorkspaceMember[]
  heatmapClipJobs   HeatmapClipJob[]
  tikTokCampaigns   TikTokCampaign[]

  @@index([email])
  @@index([stripeCustomerId])
}

model Workspace {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  description     String?
  ownerId         String
  type            String           @default("personal") // personal, family, team, agency
  autonomousLevel Int              @default(3) // 1-5: how much AI can decide autonomously
  settingsJson    String           @default("{}") // DNA config, scheduling preferences, etc.
  trialStart      DateTime?
  trialEnd        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contentItems    ContentItem[]
  memoryEntries   MemoryEntry[]
  schedulerJobs   SchedulerJob[]
  analyticsEvents AnalyticsEvent[]
  publishJobs     PublishJob[]
  apiCredentials  ApiCredential[]
  members         WorkspaceMember[]
  tasks           Task[]
  accounts        FinanceAccount[]
  transactions    Transaction[]
  budgetRules     BudgetRule[]
  financialGoals  FinancialGoal[]
  vaultDocuments  VaultDocument[]
  memories        Memory[]
  suggestions     Suggestion[]
  agentLogs       AgentLog[]
  energyEntries   EnergyEntry[]

  @@index([ownerId])
  @@index([slug])
  @@index([type])
}

// ============================================================
// SUBSCRIPTION — Stripe-backed subscription management
// ============================================================

model Subscription {
  id                  String   @id @default(cuid())
  userId              String
  plan                String   @default("free") // free, creator, pro, agency
  status              String   @default("active") // active, cancelled, expired, past_due
  stripeSubscriptionId String? @unique
  stripePriceId       String?
  currentPeriodStart  DateTime @default(now())
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stripeSubscriptionId])
}

// ============================================================
// CANONICAL CONTENT ITEM — The single source of truth
// One master article, multiple derived variants
// ============================================================

model ContentItem {
  id                  String           @id @default(cuid())
  workspaceId         String
  title               String
  subtitle            String?
  slug                String
  angle               String? // The unique angle/perspective
  topic               String?
  status              String           @default("idea") // idea, draft, editing, seo_review, ready, scheduled, published, archived, failed
  masterMarkdown      String? // The canonical master draft in markdown
  summary             String? // Auto-generated summary
  sourceNotes         String? // Raw ideas, links, voice notes
  sourceType          String           @default("idea") // idea, trend, manual, signal, repurpose
  qualityScore        Float            @default(0) // 0-100 composite score
  humanicScore        Float            @default(0) // Anti-robotic score
  seoScore            Float            @default(0) // SEO quality score
  trustScore          Float            @default(0) // Source confidence score
  humanReviewRequired Boolean          @default(false)
  version             Int              @default(1) // Immutable versioning
  parentContentId     String? // For repurposed content
  publishedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  workspace           Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  variants            ContentVariant[]
  publishJobs         PublishJob[]
  analyticsEvents     AnalyticsEvent[]
  seoData             SeoData?
  contentTags         ContentTag[]

  @@index([workspaceId])
  @@index([status])
  @@index([slug])
  @@index([publishedAt])
  @@index([parentContentId])
}

// ============================================================
// CONTENT VARIANT — Platform-specific versions derived from master
// ============================================================

model ContentVariant {
  id           String       @id @default(cuid())
  contentId    String
  platform     String // wordpress, medium, blogger, substack, beehiiv, devto, hashnode, ghost, mirror
  variantType  String       @default("full") // full, summary, thread, teaser, newsletter
  title        String?
  body         String? // Platform-adapted content
  metadataJson String       @default("{}") // Platform-specific metadata (tags, categories, featured image, etc.)
  status       String       @default("pending") // pending, ready, published, failed
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  contentItem  ContentItem  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  publishJobs  PublishJob[]

  @@unique([contentId, platform, variantType])
  @@index([contentId])
  @@index([platform])
  @@index([status])
}

// ============================================================
// SEO DATA — SEO metadata for each content item
// ============================================================

model SeoData {
  id                String      @id @default(cuid())
  contentId         String      @unique
  metaTitle         String?
  metaDescription   String?
  focusKeyword      String?
  secondaryKeywords String? // Comma-separated
  slug              String?
  headingStructure  String? // JSON: H1, H2, H3 structure
  internalLinks     String? // JSON: suggested internal links
  schemaMarkup      String? // JSON-LD schema
  readabilityScore  Float       @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  contentItem       ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

// ============================================================
// CONTENT TAGS — Flexible tagging system
// ============================================================

model ContentTag {
  id          String      @id @default(cuid())
  contentId   String
  tag         String
  category    String      @default("topic") // topic, format, niche, tone, series
  createdAt   DateTime    @default(now())
  contentItem ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([tag])
  @@index([category])
}

// ============================================================
// PUBLISH JOB — Tracks every publish attempt
// ============================================================

model PublishJob {
  id               String          @id @default(cuid())
  workspaceId      String
  contentId        String
  contentVariantId String?
  platform         String
  status           String          @default("queued") // queued, processing, published, failed, retrying
  scheduledTime    DateTime?
  publishedTime    DateTime?
  retryCount       Int             @default(0)
  maxRetries       Int             @default(3)
  lastError        String?
  responsePayload  String? // JSON: platform response
  isDryRun         Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentItem      ContentItem     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentVariant   ContentVariant? @relation(fields: [contentVariantId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([contentId])
  @@index([platform])
  @@index([status])
  @@index([scheduledTime])
}

// ============================================================
// SCHEDULER JOB — Persistent queue with priority
// ============================================================

model SchedulerJob {
  id          String    @id @default(cuid())
  workspaceId String
  jobType     String // draft_job, rewrite_job, seo_job, publish_job, analytics_job, retry_job, memory_update_job
  priority    Int       @default(5) // 1 (highest) to 10 (lowest)
  payloadJson String    @default("{}") // Job-specific data
  status      String    @default("pending") // pending, locked, running, completed, failed, dead_letter
  nextAttempt DateTime  @default(now())
  lockedBy    String? // Worker ID
  lockUntil   DateTime?
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  lastError   String?
  resultJson  String? // Job result
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([jobType])
  @@index([status])
  @@index([priority])
  @@index([nextAttempt])
}

// ============================================================
// ANALYTICS EVENT — Immutable analytics data
// ============================================================

model AnalyticsEvent {
  id          String       @id @default(cuid())
  workspaceId String
  contentId   String?
  platform    String?
  metricType  String // views, clicks, ctr, opens, shares, conversions, revenue, read_time
  metricValue Float        @default(0)
  capturedAt  DateTime     @default(now())
  rawPayload  String? // JSON: raw platform data
  source      String       @default("auto") // auto, manual, api
  createdAt   DateTime     @default(now())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentItem ContentItem? @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([contentId])
  @@index([platform])
  @@index([metricType])
  @@index([capturedAt])
}

// ============================================================
// MEMORY ENTRY — The moat. Not the model.
// Stores: what worked, what failed, preferences, patterns
// ============================================================

model MemoryEntry {
  id          String    @id @default(cuid())
  workspaceId String
  category    String // hook, topic, tone, timing, cta, format, platform, monetization, audience, style
  key         String // Unique key within category
  value       String // The memory content
  score       Float     @default(0) // Performance/confidence score
  source      String    @default("analytics") // analytics, manual, ai, experiment
  contextJson String? // JSON: additional context
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, category, key])
  @@index([workspaceId])
  @@index([category])
  @@index([key])
  @@index([score])
}

// ============================================================
// API CREDENTIAL — Encrypted platform credentials
// ============================================================

model ApiCredential {
  id             String     @id @default(cuid())
  workspaceId    String?
  userId         String
  platform       String // wordpress, medium, openrouter, google_analytics, etc.
  label          String? // Human-readable label
  encryptedToken String // Encrypted API key/token
  refreshToken   String? // Encrypted refresh token
  endpointUrl    String? // Platform API endpoint
  expiresAt      DateTime?
  scopes         String? // JSON: permission scopes
  isActive       Boolean    @default(true)
  lastUsed       DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([platform])
  @@index([isActive])
}

// ============================================================
// SYSTEM LOG — Audit trail
// ============================================================

model SystemLog {
  id           String   @id @default(cuid())
  service      String // scheduler, publisher, ai, analytics, memory, api
  level        String   @default("info") // debug, info, warn, error, critical
  action       String
  message      String
  metadataJson String   @default("{}")
  contentId    String?
  platform     String?
  userId       String?
  createdAt    DateTime @default(now())

  @@index([service])
  @@index([level])
  @@index([action])
  @@index([createdAt])
}

// ============================================================
// ENERGY SYSTEM — Track fatigue, saturation, exhaustion
// ============================================================

model EnergyEntry {
  id           String    @id @default(cuid())
  workspaceId  String
  category     String // topic_fatigue, tone_fatigue, publish_saturation, audience_exhaustion, hook_repetition
  topic        String? // The topic/tone/hook being tracked
  fatigueScore Float     @default(0) // 0 (fresh) to 100 (exhausted)
  publishCount Int       @default(0) // Number of recent publications in this category
  lastResetAt  DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([category])
  @@index([fatigueScore])
}

// ============================================================
// VIDEO PROJECT — AI-powered video creation
// ============================================================

model VideoProject {
  id             String   @id @default(cuid())
  userId         String
  workspaceId    String?
  title          String
  prompt         String?
  niche          String   @default("general") // general, horror, motivation, crypto, anime, education, tech, storytelling, documentary
  style          String?
  aspectRatio    String   @default("9:16") // 9:16, 1:1, 16:9
  status         String   @default("draft") // draft, scripting, generating, rendering, completed, failed
  videoUrl       String?
  thumbnailUrl   String?
  duration       Int      @default(0)
  resolution     String   @default("1080x1920")
  voiceId        String   @default("alloy")
  subtitleStyle  String   @default("default")
  bgmUrl         String?
  configJson     String   @default("{}")
  renderProgress Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenes         VideoScene[]
  assets         VideoAsset[]
  renderJobs     VideoRenderJob[]

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
}

// ============================================================
// VIDEO SCENE — Individual scenes within a video project
// ============================================================

model VideoScene {
  id             String   @id @default(cuid())
  projectId      String
  order          Int
  type           String   @default("image") // image, video, text, transition
  templateName   String?
  duration       Int      @default(5)
  narration      String?
  htmlContent    String?
  mediaUrl       String?
  overlayText    String?
  styleJson      String   @default("{}")
  transitionType String?
  status         String   @default("pending") // pending, generating, rendered, failed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@unique([id])
}

// ============================================================
// VIDEO ASSET — Media assets for video projects
// ============================================================

model VideoAsset {
  id           String   @id @default(cuid())
  projectId    String
  type         String   // image, audio, video, font, bgm
  name         String
  url          String
  mimeType     String?
  sizeBytes    Int      @default(0)
  width        Int?
  height       Int?
  duration     Float?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([type])
}

// ============================================================
// VIDEO RENDER JOB — Background rendering jobs
// ============================================================

model VideoRenderJob {
  id          String    @id @default(cuid())
  projectId   String
  jobType     String    @default("full") // full, scene, thumbnail, preview
  status      String    @default("queued") // queued, processing, rendering, completed, failed
  progress    Int       @default(0)
  engineUrl   String?
  outputUrl   String?
  errorMessage String?
  startedAt   DateTime?
  completedAt DateTime?
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  configJson  String    @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

// ============================================================
// VIDEO TEMPLATE — Reusable video templates
// ============================================================

model VideoTemplate {
  id           String   @id @default(cuid())
  name         String
  category     String   @default("minimal") // minimal, elegant, neon, cartoon, modern, healing, book
  resolution   String   @default("1080x1920")
  htmlTemplate String   @default("")
  thumbnailUrl String?
  description  String?
  isPremium    Boolean  @default(false)
  configJson   String   @default("{}")
  usageCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([usageCount])
}

// ============================================================
// HEATMAP CLIP JOB — YouTube heatmap analysis and clip extraction
// ============================================================

model HeatmapClipJob {
  id             String   @id @default(cuid())
  userId         String
  workspaceId    String?
  videoUrl       String
  videoId        String?
  resolution     String   @default("1080p") // 720p, 1080p, 4k
  outputFormat   String   @default("mp4") // mp4, webm
  status         String   @default("pending") // pending, analyzing, processing, completed, failed
  heatmapData    String?  // JSON
  transcriptData String?  // JSON
  peakScore      Float    @default(0)
  outputUrl      String?
  errorMessage   String?
  metadataJson   String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([videoId])
}

// ============================================================
// TIKTOK CAMPAIGN — TikTok affiliate/content campaigns
// ============================================================

model TikTokCampaign {
  id             String    @id @default(cuid())
  userId         String
  workspaceId    String?
  name           String
  campaignType   String    @default("affiliate") // affiliate, brand_collab, organic_boost, viral_clip
  status         String    @default("active") // active, paused, completed, failed
  productId      String?
  productTitle   String?
  affiliateLink  String?
  targetAudience String?
  hashtags       String    @default("[]") // JSON array
  sounds         String    @default("[]") // JSON array
  contentPillars String    @default("[]") // JSON array
  postingSchedule String   @default("{}") // JSON
  budgetCents    Int       @default(0)
  startDate      DateTime?
  endDate        DateTime?
  metricsJson    String    @default("{}") // JSON: campaign metrics
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@index([campaignType])
}

// ============================================================
// WORKSPACE MEMBER — Multi-user workspace collaboration
// ============================================================

model WorkspaceMember {
  id              String    @id @default(cuid())
  workspaceId     String
  userId          String
  role            String    @default("member") // owner, admin, member, viewer
  alias           String?
  authorityLevel  Int       @default(1) // 1-5: decision-making authority
  energyLevel     Int       @default(80) // 0-100: current energy/stamina
  stressLevel     Int       @default(20) // 0-100: current stress level
  constraints     String?   // JSON: time/availability constraints
  preferences     String?   // JSON: working preferences
  visibilityScope String?   // JSON: what data this member can see
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([role])
}

// ============================================================
// TASK — Workspace task management with cost tracking
// ============================================================

model Task {
  id                String    @id @default(cuid())
  workspaceId       String
  title             String
  description       String?
  status            String    @default("todo") // todo, in_progress, done, blocked, cancelled
  timeCost          Int       @default(0) // estimated minutes
  energyCost        Int       @default(0) // 1-10
  moneyCost         Float     @default(0) // estimated cost in dollars
  priority          String    @default("medium") // low, medium, high, critical
  assignedTo        String?   // userId of assigned member
  dependencies      String?   // JSON: array of task IDs this depends on
  dueDate           DateTime?
  completedAt       DateTime?
  aiRejected        Boolean   @default(false)
  aiRejectionReason String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([dueDate])
}

// ============================================================
// FINANCE ACCOUNT — Financial accounts per workspace
// ============================================================

model FinanceAccount {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  type        String    @default("checking") // checking, savings, investment, cash, credit
  balance     Float     @default(0)
  currency    String    @default("USD")
  isEmergency Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([workspaceId])
  @@index([type])
}

// ============================================================
// TRANSACTION — Income and expense tracking
// ============================================================

model Transaction {
  id           String         @id @default(cuid())
  workspaceId  String
  accountId    String?
  amount       Float          @default(0)
  category     String         @default("other") // salary, freelance, investment, food, transport, housing, entertainment, utilities, other
  type         String         @default("expense") // income, expense, transfer
  description  String?
  date         DateTime       @default(now())
  isRecurring  Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account      FinanceAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([accountId])
  @@index([category])
  @@index([type])
  @@index([date])
}

// ============================================================
// BUDGET RULE — Spending limits per category
// ============================================================

model BudgetRule {
  id          String    @id @default(cuid())
  workspaceId String
  category    String
  limitAmount Float     @default(0)
  period      String    @default("monthly") // weekly, monthly, yearly
  priority    String    @default("medium") // low, medium, high
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([category])
  @@index([isActive])
}

// ============================================================
// FINANCIAL GOAL — Savings and target tracking
// ============================================================

model FinancialGoal {
  id            String    @id @default(cuid())
  workspaceId   String
  name          String
  targetAmount  Float     @default(0)
  currentAmount Float     @default(0)
  deadline      DateTime?
  priority      String    @default("medium") // low, medium, high
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([deadline])
}

// ============================================================
// VAULT DOCUMENT — Secure document storage
// ============================================================

model VaultDocument {
  id          String    @id @default(cuid())
  workspaceId String
  title       String
  type        String    @default("note") // note, contract, receipt, policy, plan, report
  content     String?   // Document content (markdown/text)
  priority    String    @default("medium") // low, medium, high, critical
  scope       String    @default("workspace") // workspace, personal, shared
  visibility  String?   // JSON: who can see this
  tags        String?   // JSON: array of tags
  metadata    String?   // JSON: additional metadata
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type])
  @@index([scope])
}

// ============================================================
// MEMORY — Workspace-level memory with layered storage
// (Separate from MemoryEntry which is for content intelligence)
// ============================================================

model Memory {
  id          String    @id @default(cuid())
  workspaceId String
  layer       String    @default("short_term") // short_term, long_term, decision, procedural
  category    String?   // agent_planner, agent_finance, chat, suggestion_response, etc.
  content     String    // The memory content
  importance  Int       @default(5) // 1-10
  expiresAt   DateTime? // Optional expiration for short-term memories
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([layer])
  @@index([category])
  @@index([importance])
  @@index([expiresAt])
}

// ============================================================
// SUGGESTION — AI-generated proactive suggestions
// ============================================================

model Suggestion {
  id           String    @id @default(cuid())
  workspaceId  String
  type         String    @default("preventive") // preventive, corrective, strategic, behavioral
  agentSource  String?   // Which agent created this suggestion
  title        String
  reason       String?   // Why this suggestion was made
  consequence  String?   // What happens if accepted/ignored
  actionData   String?   // JSON: actionable data for implementation
  status       String    @default("pending") // pending, accepted, simulated, ignored
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type])
  @@index([status])
  @@index([agentSource])
}

// ============================================================
// AGENT LOG — Track AI agent decisions and reasoning
// ============================================================

model AgentLog {
  id              String    @id @default(cuid())
  workspaceId     String
  agentType       String    // planner, finance, mediator, health, education, memory, executive
  action          String    // What the agent did
  result          String?   // JSON: agent result/output
  reasoning       String?   // Why the agent decided this
  autonomousLevel Int       @default(3)
  createdAt       DateTime  @default(now())
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([agentType])
  @@index([createdAt])
}
