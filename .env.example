# =============================================================================
# GhostStudio AI — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite for local development (default)
# Switch to PostgreSQL URL for production: postgresql://user:password@localhost:5432/ghoststudio
DATABASE_URL="file:./dev.db"

# ---------------------------------------------------------------------------
# NextAuth.js — REQUIRED
# ---------------------------------------------------------------------------
# MUST be set in production. Generate with: openssl rand -base64 48
NEXTAUTH_SECRET=""

# The canonical URL of your app (used by NextAuth for callbacks)
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Public-facing URL (used in emails, sharing links, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# GitHub OAuth (optional — leave empty to disable)
# ---------------------------------------------------------------------------
# Create at: https://github.com/settings/developers
GITHUB_ID=""
GITHUB_SECRET=""

# ---------------------------------------------------------------------------
# Google OAuth (optional — leave empty to disable)
# ---------------------------------------------------------------------------
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_ID=""
GOOGLE_SECRET=""

# ---------------------------------------------------------------------------
# Stripe (Payments & Subscriptions) (optional — leave empty to disable)
# ---------------------------------------------------------------------------
# Find at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""

# Set up at: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=""

# Publishable key (safe for client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ---------------------------------------------------------------------------
# Replicate (AI Image Generation) (optional)
# ---------------------------------------------------------------------------
# Get your API token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=""

# ---------------------------------------------------------------------------
# Python Engine URLs
# ---------------------------------------------------------------------------
# Heatmap Clipper (Flask) — YouTube heatmap analysis
HEATMAP_CLIPPER_URL="http://localhost:5001"

# Pixelle Video Engine (FastAPI) — AI video generation
PIXELLE_VIDEO_URL="http://localhost:8000"

# ---------------------------------------------------------------------------
# Encryption — REQUIRED for API credential storage
# ---------------------------------------------------------------------------
# MUST be set in production. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# MUST be set in production. Generate with: openssl rand -hex 16
# WARNING: Changing ENCRYPTION_SALT will make existing encrypted data undecryptable
ENCRYPTION_SALT=""

# ---------------------------------------------------------------------------
# Puppeteer Browser Automation
# ---------------------------------------------------------------------------
# Maximum concurrent browser instances
PUPPETEER_MAX_INSTANCES="3"

# Idle timeout in milliseconds before closing a browser session
PUPPETEER_IDLE_TIMEOUT="300000"

# Run in headless mode (set to "false" for debugging)
PUPPETEER_HEADLESS="true"

# Custom Chromium executable path (leave empty for default)
PUPPETEER_EXECUTABLE_PATH=""
